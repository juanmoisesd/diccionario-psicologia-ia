      "@type": "DefinedTerm",
      "termCode": "PSY-000001",
      "name": "Ansiedad",
      "description": "Estado emocional de aprensión, tensión y preocupación anticipatoria ante amenazas percibidas, reales o imaginadas.",
      "url": "https://juanmoisesd.github.io/diccionario-psicologia-ia/terminos/ansiedad/"
    },
    {
      "@type": "DefinedTerm",
      "termCode": "PSY-000002",
      "name": "Depresión",
      "description": "Trastorno del estado de ánimo caracterizado por tristeza persistente, pérdida de interés o placer y deterioro funcional.",
      "url": "https://juanmoisesd.github.io/diccionario-psicologia-ia/terminos/depresion/"
    },
    {
      "@type": "DefinedTerm",
      "termCode": "PSY-000021",
      "name": "Burnout",
      "description": "Síndrome resultante del estrés crónico laboral no gestionado, caracterizado por agotamiento, cinismo y reducida eficacia profesional.",
      "url": "https://juanmoisesd.github.io/diccionario-psicologia-ia/terminos/burnout/"
    }
  ]
